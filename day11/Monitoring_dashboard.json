{
  "dashboard_name": "BDR & Backup Monitoring Core Dashboard",
  "version": "2026.1",
  "alerts": [
    {
      "alert_name": "BackupJobFailed",
      "promql_expr": "backup_status{job=~\"cockroach|elasticsearch|redis\"} == 0",
      "severity": "critical",
      "summary": "Сбой выполнения бэкапа {{ $labels.job }}. Требуется ручное вмешательство инженера."
    },
    {
      "alert_name": "BackupTooOld",
      "promql_expr": "(time() - backup_last_success_timestamp_seconds{job=\"cockroach\"}) > 900",
      "severity": "critical",
      "summary": "Критическое нарушение RPO! Последний успешный инкремент CockroachDB старше 15 минут."
    },
    {
      "alert_name": "DiskSpaceNearFull",
      "promql_expr": "(node_filesystem_free_bytes{mountpoint=\"/var/lib/cockroach/local_backups\"} / node_filesystem_size_bytes) * 100 < 15",
      "severity": "warning",
      "summary": "Недостаточно свободного места на бэкап-ноде: осталось менее 15% дискового пространства."
    }
  ],
  "backup_report_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["job_name", "status", "size_bytes", "duration_seconds", "timestamp", "checksum_md5"],
    "properties": {
      "job_name": {"type": "string", "enum": ["cockroach_cdc", "elasticsearch_snapshot", "redis_rdb"]},
      "status": {"type": "string", "enum": ["success", "failed"]},
      "size_bytes": {"type": "integer", "minimum": 0},
      "duration_seconds": {"type": "number", "minimum": 0},
      "timestamp": {"type": "string", "format": "date-time"},
      "checksum_md5": {"type": "string", "pattern": "^[a-f0-9]{32}$"}
    }
  }
}